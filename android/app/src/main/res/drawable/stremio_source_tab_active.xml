<?xml version="1.0" encoding="utf-8"?>
<!-- Active tab — indigo gradient pill with focus glow -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#FF536DFE"
                        android:endColor="#FF3D5AFE"
                        android:angle="90" />
                    <corners android:radius="20dp" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#00000000" />
                    <corners android:radius="20dp" />
                    <stroke
                        android:width="2dp"
                        android:color="#CCFFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FF536DFE"
                android:endColor="#FF3D5AFE"
                android:angle="90" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</selector>
