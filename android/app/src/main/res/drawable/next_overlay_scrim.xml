<?xml version="1.0" encoding="utf-8"?>
<!-- Dark scrim laid over the backdrop art on the loading/tuning overlay so the
     foreground text and spinner stay readable. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="90"
        android:startColor="#E6000000"
        android:centerColor="#B3000000"
        android:endColor="#E6000000"
        android:type="linear" />
</shape>
