<?xml version="1.0" encoding="utf-8"?>
<!-- Stremio Sources Panel Overlay — Premium right-side panel -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/stremio_sources_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#8C000000"
    android:visibility="gone"
    android:elevation="200dp">

    <!-- Right-aligned panel -->
    <FrameLayout
        android:layout_width="480dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/stremio_source_panel_bg"
        android:elevation="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="20dp"
                android:paddingTop="18dp"
                android:paddingBottom="14dp">

                <!-- Icon -->
                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/stremio_source_icon_bg">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:tint="#FFFFFFFF" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sources"
                        android:textColor="#FFFFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="-0.02" />

                    <TextView
                        android:id="@+id/stremio_sources_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:textColor="#59FFFFFF"
                        android:textSize="12sp"
                        tools:text="8 sources available" />
                </LinearLayout>

                <!-- Close hint -->
                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/stremio_source_close_bg">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:tint="#80FFFFFF" />
                </FrameLayout>
            </LinearLayout>

            <!-- Now Playing Bar -->
            <LinearLayout
                android:id="@+id/stremio_sources_now_playing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="10dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:background="@drawable/stremio_source_now_playing_bg"
                android:visibility="gone">

                <!-- Equalizer dot -->
                <View
                    android:id="@+id/stremio_sources_eq_dot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/stremio_source_eq_dot" />

                <!-- Quality badge -->
                <TextView
                    android:id="@+id/stremio_sources_now_quality"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textColor="#FF536DFE"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.05"
                    android:background="@drawable/stremio_source_quality_default"
                    tools:text="1080p" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:id="@+id/stremio_sources_now_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:ellipsize="end"
                        tools:text="Source.Name.1080p.WEB-DL" />

                    <TextView
                        android:id="@+id/stremio_sources_now_meta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#4DFFFFFF"
                        android:textSize="10sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:visibility="gone"
                        tools:text="2.4 GB" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:text="PLAYING"
                    android:textColor="#CC536DFE"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:background="#26536DFE" />
            </LinearLayout>

            <!-- Tab Bar -->
            <LinearLayout
                android:id="@+id/stremio_sources_tabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/stremio_sources_tab_direct"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:gravity="center"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/stremio_source_tab_active"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    tools:text="Direct (3)" />

                <TextView
                    android:id="@+id/stremio_sources_tab_torrent"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:gravity="center"
                    android:textColor="#80FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/stremio_source_tab_inactive"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    tools:text="Torrent (5)" />
            </LinearLayout>

            <!-- Search Bar -->
            <EditText
                android:id="@+id/stremio_sources_search"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:hint="Search sources..."
                android:textColor="#FFFFFFFF"
                android:textColorHint="#40FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/stremio_source_search_bg"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="8dp"
                android:drawableTint="#4DFFFFFF" />

            <!-- Source List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/stremio_sources_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:clipToPadding="false"
                android:focusable="true"
                android:focusableInTouchMode="true" />

        </LinearLayout>
    </FrameLayout>
</FrameLayout>
