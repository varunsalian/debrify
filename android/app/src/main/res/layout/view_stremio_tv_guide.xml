<?xml version="1.0" encoding="utf-8"?>
<!-- Stremio TV Channel Guide Overlay -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/stremio_tv_guide_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#8C000000"
    android:visibility="gone">

    <!-- Right-aligned panel -->
    <FrameLayout
        android:layout_width="480dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/iptv_guide_panel_bg"
        android:elevation="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="20dp"
                android:paddingTop="18dp"
                android:paddingBottom="14dp">

                <!-- Icon -->
                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/iptv_guide_icon_bg">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_guide"
                        android:tint="#FFFFFFFF" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Channel Guide"
                        android:textColor="#FFFFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="-0.02" />

                    <TextView
                        android:id="@+id/stremio_tv_guide_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:textColor="#59FFFFFF"
                        android:textSize="12sp"
                        tools:text="42 channels" />
                </LinearLayout>

                <!-- Close hint -->
                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/iptv_guide_close_bg">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:tint="#80FFFFFF" />
                </FrameLayout>
            </LinearLayout>

            <!-- Now Playing Bar -->
            <LinearLayout
                android:id="@+id/stremio_tv_guide_now_playing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="10dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:background="@drawable/iptv_guide_now_playing_bg"
                android:visibility="gone">

                <!-- Poster thumbnail (36×54dp with elevation) -->
                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="54dp"
                    android:elevation="3dp">

                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="54dp"
                        android:background="@drawable/stremio_tv_guide_poster_bg">

                        <ImageView
                            android:id="@+id/stremio_tv_guide_now_poster"
                            android:layout_width="36dp"
                            android:layout_height="54dp"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/stremio_tv_guide_now_letter"
                            android:layout_width="36dp"
                            android:layout_height="54dp"
                            android:gravity="center"
                            android:textColor="#FF00E5FF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="T" />
                    </FrameLayout>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:id="@+id/stremio_tv_guide_current_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        tools:text="Cinemeta: Popular Movies" />

                    <TextView
                        android:id="@+id/stremio_tv_guide_current_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        tools:text="The Dark Knight (2008)" />
                </LinearLayout>

                <!-- PLAYING badge with gradient background -->
                <TextView
                    android:id="@+id/stremio_tv_guide_playing_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:text="PLAYING"
                    android:textColor="#FFFFFFFF"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:background="@drawable/iptv_now_badge_bg"
                    android:elevation="2dp" />
            </LinearLayout>

            <!-- Search Bar -->
            <EditText
                android:id="@+id/stremio_tv_guide_search"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:hint="Search channels..."
                android:textColor="#FFFFFFFF"
                android:textColorHint="#40FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/iptv_guide_search_bg"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="8dp"
                android:drawableTint="#4DFFFFFF" />

            <!-- Channel List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/stremio_tv_guide_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:clipToPadding="false"
                android:focusable="true"
                android:focusableInTouchMode="true" />

        </LinearLayout>
    </FrameLayout>
</FrameLayout>
